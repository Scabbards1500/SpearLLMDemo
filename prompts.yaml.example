# Copy to prompts.yaml. Switch at runtime with keys 1/2/3 in the OpenCV window.

default_index: 0

prompts:
  - id: wall_table
    label: "Table against wall"
    text: >
      You are a sphere robot in a small debug house. Navigate to the table
      that is pushed against the wall. Drive forward when the table is ahead;
      turn when you need to align. Stop when you are close to that table.

  - id: explore
    label: "Explore room"
    text: >
      Explore the debug house slowly. Avoid getting stuck on walls or furniture.
      Prefer open floor space and gentle turns.

  - id: opposite_corner
    label: "Opposite corner"
    text: >
      Move from your current area toward the opposite corner of the room,
      staying on the floor and avoiding obstacles.
