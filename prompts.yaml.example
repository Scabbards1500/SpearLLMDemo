# Copy to prompts.yaml. Switch at runtime with keys 1/2/3 in the OpenCV window.

default_index: 0

prompts:
  - id: nearest_table
    label: "Nearest table"
    text: >
      You are a sphere robot in an indoor scene. Navigate to the nearest table.
      If several tables are visible, choose the closest one you can reach.
      Explore until a table appears, then approach it and stop when close.

  - id: explore
    label: "Explore room"
    text: >
      Explore the debug house slowly. Avoid getting stuck on walls or furniture.
      Prefer open floor space and gentle turns.

  - id: opposite_corner
    label: "Opposite corner"
    text: >
      Move from your current area toward the opposite corner of the room,
      staying on the floor and avoiding obstacles.
